# ---- NLP inference service (production) ----
# Copy to .env.nlp.prod on the VPS and fill real values. Do NOT commit the real file.
# Var names below match backend-services/nlp-inference-service/services/config.py
# and main.py exactly.

# CORS: comma-separated allowed frontend origins (read in main.py).
# MUST match your public site origin or the service rejects requests.
ALLOWED_ORIGINS=https://<your-domain>

# Which paraphrase backend to use:
#   ctranslate2 (default) -> CPU, humarin/T5 INT8 (~2 GB RAM, no GPU)
#   llm                   -> small instruct model via an OpenAI-compatible GPU server
PARAPHRASE_BACKEND=ctranslate2

# --- LLM backend settings (only used when PARAPHRASE_BACKEND=llm) ---
# Base URL of the OpenAI-compatible server; include the /v1 suffix.
# Must use a different port than 8080 (the NLP service itself).
LLM_SERVER_URL=http://llm-server:8081/v1
LLM_MODEL=phi-4-mini
LLM_TIMEOUT=30

# --- Model directories (mounted volume; see docker-compose.prod.yml) ---
PARAPHRASE_MODEL_PATH=/models/paraphrase
TRANSLATION_MODEL_PATH=/models/translation
