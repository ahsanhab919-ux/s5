# ---- NLP inference service (production) ----
# Copy to .env.nlp.prod on the VPS and fill real values. Do NOT commit the real file.

# Comma-separated list of allowed frontend origins (CORS).
# MUST match your public site origin or the service rejects requests.
ALLOWED_ORIGINS=https://<your-domain>

# Uvicorn / server
HOST=0.0.0.0
PORT=8080
WORKERS=1
LOG_LEVEL=info

# Model / cache settings (adjust to your setup)
MODEL_CACHE_DIR=/models
# HF_HOME=/models/hf

# Add any provider API keys the service needs below (keep secret)
# OPENAI_API_KEY=
