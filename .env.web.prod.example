# ---- Next.js web (production) ----
# Copy to .env.web.prod on the VPS and fill real values. Do NOT commit the real file.

NODE_ENV=production
PORT=3000
NEXT_TELEMETRY_DISABLED=1

# Where the frontend reaches the NLP backend (container service name in compose)
NLP_SERVICE_URL=http://nlp-service:8080

# Public base URL of the deployed site
NEXT_PUBLIC_SITE_URL=https://<your-domain>

# Auth / session (generate strong random values)
NEXTAUTH_URL=https://<your-domain>
NEXTAUTH_SECRET=__change_me__

# Cloudinary (images)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Add any other NEXT_PUBLIC_* / server-only keys your app requires below
